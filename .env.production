NODE_ENV=production
PORT=4000

# JWT
JWT_SECRET=use_long_random_production_secret
JWT_EXPIRES_IN=1d

# PostgreSQL (prod)
DB_HOST=your-prod-db-host
DB_PORT=5432
DB_USER=your-prod-db-user
DB_PASS=your-prod-db-password
DB_NAME=cmab_prod
DB_SYNC=false
DB_LOGGING=false

# Gmail SMTP (prod)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_gmail@domain.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM=CMAB <your_gmail@domain.com>

# OTP
OTP_EXP_MINUTES=10