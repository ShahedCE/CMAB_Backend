NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=dev_super_secret_change_this
JWT_EXPIRES_IN=1d

# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_local_pg_password
